# =============================================================================
# STACK 100% GRATUITA — validada em 2026-06-25 contra as páginas de pricing
# reais de Vercel, Upstash e Resend. Nenhum destes serviços cobra
# automaticamente sem você fazer upgrade manual / introduzir cartão.
# =============================================================================

# --- Sessão da aplicação (login email + código) ---
SESSION_SECRET=                  # gerar com: openssl rand -base64 32

# --- O único email autorizado a fazer login (utilizador único) ---
ACCOUNT_OWNER_EMAIL=             # o email com que criou a conta Resend

# --- Envio de email do código OTP (Resend free tier, sem domínio) ---
RESEND_API_KEY=
# Usa-se o endereço de sandbox onboarding@resend.dev — sem domínio próprio,
# só consegue enviar para ACCOUNT_OWNER_EMAIL, o que é suficiente aqui.

# --- Upstash Redis (free tier, 500K comandos/mês, sem cartão) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Freddy MCP ---
# [Certo] Confirmado em https://freddy.coach/agents: OAuth 2.0 Device
# Authorization Grant (RFC 8628) + Dynamic Client Registration (RFC 7591).
# Não há nenhum valor a copiar para aqui — o registo do client e os tokens
# são geridos automaticamente em runtime (lib/freddy/oauth.ts) e guardados
# no Upstash Redis. O único passo manual é abrir /connect-freddy uma vez
# após o deploy e aprovar no browser.

# --- Treinador IA (Groq, free tier, sem cartão) ---
# Criar conta em console.groq.com, gerar API key. 30k tokens/min, 14400 pedidos/dia, gratuito.
GROQ_API_KEY=

# --- strava-lab (app externa, calçado/segmentos) ---
# URL do strava-lab na Vercel, sem barra final.
STRAVA_LAB_API_URL=https://strava-lab.vercel.app
# A mesma DATA_API_KEY configurada no projeto strava-lab.
STRAVA_LAB_API_KEY=
